# Blender MCP - Variables de entorno
# Copiar este archivo como .env y completar con valores reales
# .env NO se versiona (está en .gitignore)

# Conexión con Blender (host Windows desde Docker)
BLENDER_RPC_HOST=host.docker.internal
BLENDER_RPC_PORT=9876

# Telemetría (desactivar para no enviar datos a Supabase)
DISABLE_TELEMETRY=true

# Opcional: API keys para integraciones externas
# SKETCHFAB_API_KEY=
# HYPER3D_API_KEY=
